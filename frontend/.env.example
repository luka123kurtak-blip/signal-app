# --- Локальна розробка (телефон у тій самій Wi‑Fi) ---
# IP ПК: ipconfig → IPv4. Скопіюй у .env.local і перезапусти dev-сервер.
# DEV_ALLOWED_ORIGINS=192.168.31.55,192.168.31.55:3000

# --- Продакшн (стабільна адреса, не змінюється) ---
# На Vercel → Settings → Environment Variables:
# NEXT_PUBLIC_SOCKET_URL=https://signal-app-backend.onrender.com
